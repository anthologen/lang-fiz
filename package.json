{
  "name": "@formulavize/lang-fiz",
  "version": "2.1.0",
  "description": "fiz language support for CodeMirror",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "cm-buildhelper src/index.ts",
    "test": "cm-runtests",
    "format": "prettier --write .",
    "dev:watch": "chokidar '{src,test}/**/*.ts' -c 'pnpm run all'",
    "all": "run-s build test"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@formulavize/lezer-fiz": "^2.1.0"
  },
  "devDependencies": {
    "@codemirror/buildhelper": "^1.0.2",
    "@codemirror/state": "^6.6.0",
    "@lezer/common": "^1.5.1",
    "chokidar-cli": "^3.0.0",
    "ist": "^1.1.7",
    "mocha": "10.8.2",
    "npm-run-all": "^4.1.5",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/formulavize/lang-fiz.git"
  },
  "author": "anthologen",
  "license": "MIT",
  "homepage": "https://github.com/formulavize/lang-fiz#readme"
}
